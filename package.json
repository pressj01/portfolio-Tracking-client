{
  "name": "portfolio-tracking-client",
  "version": "1.0.0",
  "private": true,
  "description": "Portfolio Tracking Desktop Application",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:all": "concurrently --kill-others \"py backend/app.py\" \"vite\"",
    "build": "vite build",
    "electron": "electron .",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\""
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "electron": "^33.0.0",
    "vite": "^6.0.0",
    "wait-on": "^8.0.0"
  }
}
