{
  "name": "portfolio-tracking-client",
  "version": "1.16.0",
  "private": true,
  "description": "Portfolio Tracking Desktop Application",
  "author": "Press",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:all": "concurrently --kill-others \"py backend/app.py\" \"vite\"",
    "start": "concurrently --kill-others \"py backend/app.py\" \"wait-on http://localhost:5001/api/profiles && electron .\"",
    "build": "vite build",
    "electron": "electron .",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "dist": "npm run build && electron-builder --win"
  },
  "build": {
    "appId": "com.portfolio-tracker.client",
    "productName": "Portfolio Tracking Client",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/main-prod.js",
      "!backend/**",
      "!src/**",
      "!installer/**",
      "!deploy/**",
      "!node_modules/**"
    ],
    "extraMetadata": {
      "main": "electron/main-prod.js"
    },
    "extraResources": [
      {
        "from": "installer/flask-dist/backend",
        "to": "flask-backend",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": null
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Portfolio Tracker"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ],
      "category": "public.app-category.finance"
    },
    "dmg": {
      "title": "Portfolio Tracker",
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    }
  },
  "dependencies": {
    "plotly.js": "^3.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-plotly.js": "^2.6.0",
    "react-router-dom": "^7.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^26.8.1",
    "vite": "^6.0.0",
    "wait-on": "^8.0.0"
  }
}
